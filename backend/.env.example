PORT=4000
NODE_ENV=development
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
DATABASE_URL=postgres://postgres:postgres@localhost:5432/global_t20
FRONTEND_ORIGIN=http://localhost:5173
INACTIVITY_CHECK_INTERVAL_MINUTES=60
STREET_CRICKET_API_BASE_URL=https://streetcricketballsim.vercel.app
STREET_CRICKET_API_KEYS=replace_with_api_key
STREET_CRICKET_BALL_API_ENABLED=true
STREET_CRICKET_FULL_MATCH_API_ENABLED=true
STREET_CRICKET_USE_FOR_BATCH_SIMS=true
STREET_CRICKET_TIMEOUT_MS=1800
STREET_CRICKET_BATCH_CHUNK_SIZE=10
STREET_CRICKET_BATCH_CHUNK_PAUSE_MS=60000
